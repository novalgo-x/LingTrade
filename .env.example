# LLM provider configuration. Copy to .env locally and fill in real values.
# Do not commit .env or real API keys.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=3

# Optional A-share data providers. Leave blank to use offline/mock sample data.
TUSHARE_TOKEN=
TUSHARE_BASE_URL=http://api.tushare.pro
AKTOOLS_BASE_URL=
XUEQIU_TOKEN=
COPILOT_DATA_MODE=mock
COPILOT_LLM_MODE=mock
DATA_REQUEST_TIMEOUT_MS=30000

# App runtime
APP_HOST=127.0.0.1
APP_PORT=26032
WEB_SERVER_PORT=26681
